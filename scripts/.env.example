# anthropic_watcher.py - environment variables
# Copy to scripts/.env for local runs. Do NOT commit scripts/.env.
# For the GitHub Actions workflow, set these as repo secrets instead.

# Required
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-google-app-password
EMAIL_TO=you@gmail.com

# Optional
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_FROM=you@gmail.com

# Optional - enables AI-generated TL;DR at the top of each email.
# Get a key from https://console.anthropic.com/.
ANTHROPIC_API_KEY=sk-ant-...

# Optional - set to 1 to send the brief even when nothing is new.
# The GitHub Actions workflow sets this automatically during the 7 AM ET window.
FORCE_DAILY=0

# Optional - how far back to include in the email digest.
LOOKBACK_DAYS=30
